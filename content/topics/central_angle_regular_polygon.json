  "synopsis_cards": [
    {
      "title": "What is a central angle?",
      "body": "A full turn around a point is 360°. If a regular polygon is divided equally from the center, each part has the same angle."
    },
    {
      "title": "Formula",
      "body": "Central angle = 360° ÷ number of sides"
    },
    {
      "title": "Why it matters",
      "body": "Central angles help us understand regular polygons and solve geometry problems step by step."
    }
  ],
  "formulae": [
    "Central angle = 360° / n"
  ],
