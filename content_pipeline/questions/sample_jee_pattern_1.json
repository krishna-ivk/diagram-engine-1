      "text": "64 cm²",
      "is_correct": false
    },
    {
      "label": "C",
      "text": "32 cm²",
      "is_correct": false
    },
    {
      "label": "D",
      "text": "32(2-√2) cm²",
      "is_correct": true
    }
  ],
  "answer": "D",
  "solution": {
    "method": "Area by subtracting corner triangles",
    "steps": [
      {
        "step_number": 1,
        "description": "Visualize the square and octagon",
        "calculation": "Square side = 8 cm, area = 64 cm²"
      },
      {
        "step_number": 2,
        "description": "Find the corner triangles that are removed",
        "calculation": "Each corner triangle is isosceles right triangle with legs = 4 cm"
      },
      {
        "step_number": 3,
        "description": "Calculate area of one corner triangle",
        "calculation": "Area = (1/2) × 4 × 4 = 8 cm²"
      },
      {
        "step_number": 4,
        "description": "Total area of 4 corner triangles",
        "calculation": "4 × 8 = 32 cm²"
      },
      {
        "step_number": 5,
        "description": "Octagon area = Square area - Corner triangles area",
        "calculation": "64 - 32 = 32 cm²"
      }
    ],
    "final_answer": "32 cm²"
  },
