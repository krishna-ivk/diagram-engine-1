{
  "question_id": "bridge_trigonometry_basic_1",
  "question_text": "In a right triangle ABC with right angle at B, if AB = 3 and BC = 4, find sin(A).",
  "question_type": "numerical",
  "answer": 0.6,
  "solution": {
    "method": "Trigonometric ratio definition",
    "steps": [
      {
        "step_number": 1,
        "description": "Identify the sides relative to angle A",
        "calculation": "Opposite side to angle A is BC = 4, Hypotenuse is AC"
      },
      {
        "step_number": 2,
        "description": "Find hypotenuse using Pythagorean theorem",
        "calculation": "AC² = AB² + BC² = 3² + 4² = 9 + 16 = 25, so AC = 5"
      },
      {
        "step_number": 3,
        "description": "Apply sin formula: sin(A) = opposite/hypotenuse",
        "calculation": "sin(A) = BC/AC = 4/5 = 0.8"
      }
    ],
    "final_answer": "0.8"
  },
