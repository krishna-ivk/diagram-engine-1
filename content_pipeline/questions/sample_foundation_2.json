{
  "question_id": "foundation_distance_basic_1",
  "question_text": "Find the distance between the points (0, 0) and (3, 4).",
  "question_type": "numerical",
  "answer": 5,
  "solution": {
    "method": "Distance formula",
    "steps": [
      {
        "step_number": 1,
        "description": "Use distance formula: √[(x₂-x₁)² + (y₂-y₁)²]",
        "calculation": "√[(3-0)² + (4-0)²]"
      },
      {
        "step_number": 2,
        "description": "Calculate the differences",
        "calculation": "√[3² + 4²]"
      },
      {
        "step_number": 3,
        "description": "Square the numbers",
        "calculation": "√[9 + 16]"
      },
      {
        "step_number": 4,
        "description": "Add and take square root",
        "calculation": "√25 = 5"
      }
    ],
    "final_answer": "5"
  },
